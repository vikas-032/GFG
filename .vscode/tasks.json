{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run with Output File",
            "type": "shell",
            "command": "cmd",
            "args": [
    "/c",
    "cl.exe /Zi /EHsc /nologo /Fe:${fileDirname}\\demo.exe ${file} && ${fileDirname}\\demo.exe < ${fileDirname}\\input.txt > ${fileDirname}\\output.txt"
],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "echo": false,
                "reveal": "never",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}